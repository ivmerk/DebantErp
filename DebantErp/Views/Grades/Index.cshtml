@using DebantErp.ViewModels
@model GradeListViewModel

@{
    ViewData["Title"] = "Розряди";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Workspace" asp-action="Index">Дані</a></li>
        <li class="breadcrumb-item active" aria-current="page">Розряди</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Розряди</h1>
    @if (Model.Edit)
    {
        <a class="btn btn-outline-secondary" asp-action="Index" asp-route-page="@Model.Page">Готово</a>
    }
    else
    {
        <a class="btn btn-primary" asp-action="Index" asp-route-page="@Model.Page" asp-route-edit="true">Змінити</a>
    }
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (Model.Edit)
{
    <form asp-controller="Grades" asp-action="Create" method="post" class="row g-2 mb-4 align-items-end">
        <div class="col-md-3">
            <label class="form-label mb-0">Розряд</label>
            <input name="Grade" type="number" min="1" step="1" class="form-control" required />
        </div>
        <div class="col-md-3">
            <label class="form-label mb-0">Денна ставка</label>
            <input name="DailyRate" type="number" min="0" step="0.01" class="form-control" required />
        </div>
        <div class="col-md-3">
            <label class="form-label mb-0">Дата введення</label>
            <input name="EffectiveDate" type="date" value="@DateTime.Today.ToString("yyyy-MM-dd")" class="form-control" required />
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-primary w-100">Додати</button>
        </div>
    </form>
}

@if (Model.Items.Count == 0)
{
    <p class="text-muted">Розрядів поки немає.</p>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th style="width:140px">Розряд</th>
                <th style="width:180px">Денна ставка</th>
                <th style="width:200px">Оклад (21 р.д.)</th>
                <th style="width:200px">Дата введення</th>
                <th style="width:320px"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model.Items)
            {
                var g = row.Grade;
                <tr>
                    @if (Model.Edit)
                    {
                        <td>@g.Grade</td>
                        <td colspan="3">
                            <form asp-controller="Grades" asp-action="Change" asp-route-id="@g.Id"
                                  asp-route-page="@Model.Page" method="post" class="row g-2 align-items-center">
                                <div class="col">
                                    <input name="DailyRate" value="@g.DailyRate" type="number"
                                           min="0" step="0.01" class="form-control form-control-sm" required />
                                </div>
                                <div class="col-auto text-muted small" style="min-width:150px">
                                    оклад: <strong>@g.MonthlySalary.ToString("0.00")</strong>
                                </div>
                                <div class="col">
                                    <input name="EffectiveDate" value="@g.EffectiveDate.ToString("yyyy-MM-dd")"
                                           type="date" class="form-control form-control-sm" required />
                                </div>
                                <div class="col-auto">
                                    <button type="submit" class="btn btn-sm btn-outline-primary">Зберегти</button>
                                </div>
                            </form>
                        </td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-secondary"
                                    data-bs-toggle="collapse" data-bs-target="#hist-@g.Id"
                                    @(row.History.Count == 0 ? "disabled" : "")>Історія (@row.History.Count)</button>
                            <form asp-controller="Grades" asp-action="Delete" asp-route-id="@g.Id"
                                  asp-route-page="@Model.Page" method="post" class="d-inline"
                                  onsubmit="return confirm('Видалити розряд @g.Grade?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Видалити</button>
                            </form>
                        </td>
                    }
                    else
                    {
                        <td>@g.Grade</td>
                        <td>@g.DailyRate</td>
                        <td>@g.MonthlySalary.ToString("0.00")</td>
                        <td>@g.EffectiveDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-secondary"
                                    data-bs-toggle="collapse" data-bs-target="#hist-@g.Id"
                                    @(row.History.Count == 0 ? "disabled" : "")>Історія (@row.History.Count)</button>
                        </td>
                    }
                </tr>
                @if (row.History.Count > 0)
                {
                    <tr class="collapse" id="hist-@g.Id">
                        <td colspan="5" class="bg-light">
                            <div class="small text-muted mb-1">Попередні версії:</div>
                            <ul class="list-unstyled mb-0">
                                @foreach (var h in row.History)
                                {
                                    <li>ставка <strong>@h.DailyRate</strong>, оклад <strong>@h.MonthlySalary.ToString("0.00")</strong>, з <strong>@h.EffectiveDate.ToString("yyyy-MM-dd")</strong>
                                        <span class="text-muted">— до @h.CreatedAt.ToString("yyyy-MM-dd")</span></li>
                                }
                            </ul>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Пагінація">
            <ul class="pagination">
                <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-edit="@Model.Edit">Назад</a>
                </li>
                @for (var p = 1; p <= Model.TotalPages; p++)
                {
                    <li class="page-item @(p == Model.Page ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@p" asp-route-edit="@Model.Edit">@p</a>
                    </li>
                }
                <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-edit="@Model.Edit">Вперед</a>
                </li>
            </ul>
        </nav>
    }
}
