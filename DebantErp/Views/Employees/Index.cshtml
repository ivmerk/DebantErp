@using DebantErp.ViewModels
@model EmployeeListViewModel

@{
  ViewData["Title"] = "Работники";
  var ro = !Model.Edit; // режим просмотра
  var inCls = ro ? "form-control-plaintext form-control-sm" : "form-control form-control-sm";
}

<nav aria-label="breadcrumb">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a asp-controller="Workspace" asp-action="Index">Данные</a></li>
    <li class="breadcrumb-item active" aria-current="page">Работники</li>
  </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="mb-0">Работники</h1>
  @if (Model.Edit)
  {
    <a class="btn btn-outline-secondary" asp-action="Index" asp-route-page="@Model.Page">Готово</a>
  }
  else
  {
    <a class="btn btn-primary" asp-action="Index" asp-route-page="@Model.Page" asp-route-edit="true">Изменить</a>
  }
</div>

@if (TempData["Success"] != null)
{
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    @TempData["Success"]
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
}
@if (TempData["Error"] != null)
{
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    @TempData["Error"]
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
}

@if (Model.Edit)
{
  <form asp-controller="Employees" asp-action="Create" method="post" class="card card-body mb-4">
    <h5 class="card-title">Новый работник</h5>
    <div class="row g-2">
      <div class="col-md-4">
        <input name="LastName" class="form-control" placeholder="Фамилия" required maxlength="50" />
      </div>
      <div class="col-md-4">
        <input name="FirstName" class="form-control" placeholder="Имя" required maxlength="50" />
      </div>
      <div class="col-md-4">
        <input name="MiddleName" class="form-control" placeholder="Отчество" required maxlength="50" />
      </div>
      <div class="col-md-4">
        <input name="Phone" class="form-control" placeholder="Телефон" required />
      </div>
      <div class="col-md-4">
        <input name="Email" type="email" class="form-control" placeholder="Почта" required />
      </div>
      <div class="col-md-4">
        <input name="TaxCode" class="form-control" placeholder="ИНН" required />
      </div>
      <div class="col-md-4">
        <input name="Address" class="form-control" placeholder="Адрес" required />
      </div>
      <div class="col-md-4">
        <input name="BirthDate" type="date" class="form-control" required />
      </div>
      <div class="col-md-4">
        <select name="Gender" class="form-select" required>
          <option value="" disabled selected>Пол</option>
          <option value="male">Мужской</option>
          <option value="female">Женский</option>
        </select>
      </div>
    </div>
    <div class="mt-3">
      <button type="submit" class="btn btn-primary">Добавить</button>
    </div>
  </form>
}

@if (Model.Items.Count == 0)
{
  <p class="text-muted">Работников пока нет.</p>
}
else
{
  <table class="table table-striped align-middle">
    <thead>
      <tr>
        <th>Фамилия</th>
        <th>Имя</th>
        <th>Отчество</th>
        <th style="width:320px"></th>
      </tr>
    </thead>
    <tbody>
      @foreach (var row in Model.Items)
      {
        var e = row.Employee;
        var d = row.Details;
        DateTime.TryParse(d.BirthDate, out var birthDate);
        var isMale = string.Equals(d.Gender, "Male", StringComparison.OrdinalIgnoreCase);
        // минимально допустимая дата назначения — дата последней уже назначенной специальности
        var minFrom = row.Assignments.Count > 0 ? row.Assignments.Max(a => a.DateFrom).ToString("yyyy-MM-dd") : null;
        <tr>
          <td colspan="3">
            <form asp-controller="Employees" asp-action="Edit" asp-route-id="@e.Id" asp-route-page="@Model.Page"
                  method="post">
              <div class="row g-2 align-items-center">
                <div class="col">
                  <input name="LastName" value="@e.LastName" class="@inCls" readonly="@ro" required maxlength="50" />
                </div>
                <div class="col">
                  <input name="FirstName" value="@e.FirstName" class="@inCls" readonly="@ro" required maxlength="50" />
                </div>
                <div class="col">
                  <input name="MiddleName" value="@e.MiddleName" class="@inCls" readonly="@ro" required maxlength="50" />
                </div>
                <div class="col-auto">
                  <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="collapse"
                          data-bs-target="#details-@e.Id">Детали</button>
                  <a class="btn btn-sm btn-outline-info" asp-action="LaborCosts" asp-route-id="@e.Id">Трудозатраты</a>
                  @if (Model.Edit)
                  {
                    <button type="submit" class="btn btn-sm btn-outline-primary">Сохранить</button>
                  }
                </div>
              </div>
              <div class="collapse mt-2" id="details-@e.Id">
                <div class="row g-2">
                  <div class="col-md-4">
                    <label class="form-label form-label-sm mb-0">Телефон</label>
                    <input name="Phone" value="@d.Phone" class="@inCls" readonly="@ro" />
                  </div>
                  <div class="col-md-4">
                    <label class="form-label form-label-sm mb-0">Почта</label>
                    <input name="Email" type="email" value="@d.Email" class="@inCls" readonly="@ro" />
                  </div>
                  <div class="col-md-4">
                    <label class="form-label form-label-sm mb-0">ИНН</label>
                    <input name="TaxCode" value="@d.TaxCode" class="@inCls" readonly="@ro" />
                  </div>
                  <div class="col-md-4">
                    <label class="form-label form-label-sm mb-0">Адрес</label>
                    <input name="Address" value="@d.Address" class="@inCls" readonly="@ro" />
                  </div>
                  <div class="col-md-4">
                    <label class="form-label form-label-sm mb-0">Дата рождения</label>
                    <input name="BirthDate" type="date"
                           value="@(birthDate == default ? "" : birthDate.ToString("yyyy-MM-dd"))" class="@inCls"
                           readonly="@ro" />
                  </div>
                  <div class="col-md-4">
                    <label class="form-label form-label-sm mb-0">Пол</label>
                    @if (Model.Edit)
                    {
                      <select name="Gender" class="form-select form-select-sm">
                        <option value="male" selected="@isMale">Мужской</option>
                        <option value="female" selected="@(!isMale)">Женский</option>
                      </select>
                    }
                    else
                    {
                      <input class="@inCls" readonly value="@(isMale ? "Мужской" : "Женский")" />
                    }
                  </div>
                </div>
              </div>
            </form>

            @* Специальности работника — показ + (в режиме правки) назначение/снятие.
                           Формы вынесены ОТДЕЛЬНО от формы редактирования: вложенные <form> недопустимы. *@
            <div class="mt-2">
              <span class="text-muted small me-2">Специальность:</span>
              @if (row.Assignments.Count == 0)
              {
                <span class="text-muted small fst-italic">не назначены</span>
              }
              @foreach (var a in row.Assignments)
              {
                @if (Model.Edit)
                {
                  <form asp-controller="Employees" asp-action="RemoveSpecialty" asp-route-id="@e.Id"
                        asp-route-assignmentId="@a.Id" asp-route-page="@Model.Page" method="post" class="d-inline-block me-1 mb-1"
                        onsubmit="return confirm('Снять специальность «@a.SpecialtyName»?');">
                    <span class="badge text-bg-light border">
                      <span class="text-dark fw-semibold">@a.SpecialtyName</span>
                      <span class="text-dark">с @a.DateFrom.ToString("yyyy-MM-dd")</span>
                      <button type="submit" class="btn-close ms-1 align-middle" style="font-size:.6rem"
                              aria-label="Снять"></button>
                    </span>
                  </form>
                }
                else
                {
                  <span class="badge text-bg-light border me-1 mb-1">
                    <span class="text-dark fw-semibold">@a.SpecialtyName</span>
                    <span class="text-muted">с @a.DateFrom.ToString("yyyy-MM-dd")</span>
                  </span>
                }
              }

              @if (Model.Edit)
              {
                <form asp-controller="Employees" asp-action="AssignSpecialty" asp-route-id="@e.Id"
                      asp-route-page="@Model.Page" method="post" class="row g-2 mt-1">
                  <div class="col-auto">
                    <select name="specialtyId" class="form-select form-select-sm" required>
                      <option value="" disabled selected>Специальность…</option>
                      @foreach (var sp in Model.Specialties)
                      {
                        <option value="@sp.Id">@sp.Name</option>
                      }
                    </select>
                  </div>
                  <div class="col-auto">
                    <input name="dateFrom" type="date" min="@minFrom" class="form-control form-control-sm" required />
                  </div>
                  <div class="col-auto">
                    <button type="submit" class="btn btn-sm btn-outline-primary">Назначить</button>
                  </div>
                </form>
              }
            </div>
          </td>
          <td>
            @if (Model.Edit)
            {
              <form asp-controller="Employees" asp-action="Delete" asp-route-id="@e.Id" asp-route-page="@Model.Page"
                    method="post" onsubmit="return confirm('Удалить работника «@e.LastName @e.FirstName»?');">
                <button type="submit" class="btn btn-sm btn-outline-danger">Удалить</button>
              </form>
            }
          </td>
        </tr>
      }
    </tbody>
  </table>

  @if (Model.TotalPages > 1)
  {
    <nav aria-label="Пагинация">
      <ul class="pagination">
        <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
          <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-edit="@Model.Edit">Назад</a>
        </li>
        @for (var p = 1; p <= Model.TotalPages; p++)
        {
          <li class="page-item @(p == Model.Page ? "active" : "")">
            <a class="page-link" asp-action="Index" asp-route-page="@p" asp-route-edit="@Model.Edit">@p</a>
          </li>
        }
        <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
          <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-edit="@Model.Edit">Вперёд</a>
        </li>
      </ul>
    </nav>
  }
}
