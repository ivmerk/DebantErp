@using DebantErp.ViewModels
@model ProductionOperationListViewModel

@{
    ViewData["Title"] = "Виробничі операції";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Workspace" asp-action="Index">Дані</a></li>
        <li class="breadcrumb-item active" aria-current="page">Операції</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Виробничі операції</h1>
    @if (Model.Edit)
    {
        <a class="btn btn-outline-secondary" asp-action="Index" asp-route-page="@Model.Page">Готово</a>
    }
    else
    {
        <a class="btn btn-primary" asp-action="Index" asp-route-page="@Model.Page" asp-route-edit="true">Змінити</a>
    }
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (Model.Edit)
{
    <form asp-controller="ProductionOperations" asp-action="Create" method="post" class="row g-2 mb-4">
        <div class="col-auto">
            <input name="Code" class="form-control" placeholder="Код" required maxlength="15" />
        </div>
        <div class="col-auto">
            <input name="Name" class="form-control" placeholder="Нова операція" required maxlength="50" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">Додати</button>
        </div>
    </form>
}

@if (Model.Items.Count == 0)
{
    <p class="text-muted">Операцій поки немає.</p>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th style="width:160px">Код</th>
                <th>Назва</th>
                @if (Model.Edit)
                {
                    <th style="width:200px"></th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var o in Model.Items)
            {
                <tr>
                    @if (Model.Edit)
                    {
                        <td colspan="2">
                            <form asp-controller="ProductionOperations" asp-action="Edit" asp-route-id="@o.Id"
                                  asp-route-page="@Model.Page" method="post" class="d-flex gap-2">
                                <input name="Code" value="@o.Code" class="form-control form-control-sm"
                                       style="max-width:160px" required maxlength="15" />
                                <input name="Name" value="@o.Name" class="form-control form-control-sm"
                                       required maxlength="50" />
                                <button type="submit" class="btn btn-sm btn-outline-primary">Зберегти</button>
                            </form>
                        </td>
                        <td>
                            <form asp-controller="ProductionOperations" asp-action="Delete" asp-route-id="@o.Id"
                                  asp-route-page="@Model.Page" method="post"
                                  onsubmit="return confirm('Видалити операцію «@o.Name»?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Видалити</button>
                            </form>
                        </td>
                    }
                    else
                    {
                        <td>@o.Code</td>
                        <td>@o.Name</td>
                    }
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Пагінація">
            <ul class="pagination">
                <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-edit="@Model.Edit">Назад</a>
                </li>
                @for (var p = 1; p <= Model.TotalPages; p++)
                {
                    <li class="page-item @(p == Model.Page ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@p" asp-route-edit="@Model.Edit">@p</a>
                    </li>
                }
                <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-edit="@Model.Edit">Вперед</a>
                </li>
            </ul>
        </nav>
    }
}
