@using DebantErp.ViewModels
@model SpecialtyListViewModel

@{
    ViewData["Title"] = "Специальности";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Workspace" asp-action="Index">Данные</a></li>
        <li class="breadcrumb-item active" aria-current="page">Специальности</li>
    </ol>
</nav>

<h1 class="mb-3">Специальности</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form asp-controller="Workspace" asp-action="SpecialtyCreate" method="post" class="row g-2 mb-4">
    <div class="col-auto">
        <input name="Name" class="form-control" placeholder="Новая специальность" required maxlength="50" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Добавить</button>
    </div>
</form>

@if (Model.Items.Count == 0)
{
    <p class="text-muted">Специальностей пока нет.</p>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Название</th>
                <th style="width:200px"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model.Items)
            {
                <tr>
                    <td>
                        <form asp-controller="Workspace" asp-action="SpecialtyEdit" asp-route-id="@s.Id"
                              asp-route-page="@Model.Page" method="post" class="d-flex gap-2">
                            <input name="Name" value="@s.Name" class="form-control form-control-sm"
                                   required maxlength="50" />
                            <button type="submit" class="btn btn-sm btn-outline-primary">Сохранить</button>
                        </form>
                    </td>
                    <td>
                        <form asp-controller="Workspace" asp-action="SpecialtyDelete" asp-route-id="@s.Id"
                              asp-route-page="@Model.Page" method="post"
                              onsubmit="return confirm('Удалить специальность «@s.Name»?');">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Удалить</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Пагинация">
            <ul class="pagination">
                <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Specialties" asp-route-page="@(Model.Page - 1)">Назад</a>
                </li>
                @for (var p = 1; p <= Model.TotalPages; p++)
                {
                    <li class="page-item @(p == Model.Page ? "active" : "")">
                        <a class="page-link" asp-action="Specialties" asp-route-page="@p">@p</a>
                    </li>
                }
                <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Specialties" asp-route-page="@(Model.Page + 1)">Вперёд</a>
                </li>
            </ul>
        </nav>
    }
}
