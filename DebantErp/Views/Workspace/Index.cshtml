@{
    ViewData["Title"] = "Дані";
}

<h1 class="mb-4">З якою сутністю працюємо?</h1>

<div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-3">
    @{
        var tiles = new[]
        {
            ("Працівники", "Співробітники та їхні дані", "Employees", "Index"),
            ("Спеціальності", "Довідник спеціальностей", "Specialties", "Index"),
            ("Операції", "Виробничі операції", "ProductionOperations", "Index"),
            ("Розцінки", "Виробничі розцінки", "Rates", "Index"),
            ("Замовлення", "Замовлення та трудовитрати", "Orders", "Index"),
        };
    }
    @foreach (var (title, desc, controller, action) in tiles)
    {
        <div class="col">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@title</h5>
                    <p class="card-text text-muted flex-grow-1">@desc</p>
                    <a class="btn btn-primary mt-2" asp-controller="@controller" asp-action="@action">Відкрити</a>
                </div>
            </div>
        </div>
    }
</div>
