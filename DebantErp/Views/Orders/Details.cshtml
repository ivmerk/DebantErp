@using DebantErp.ViewModels
@model OrderDetailsViewModel

@{
    ViewData["Title"] = $"Заказ {Model.Order.Number}";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Workspace" asp-action="Index">Данные</a></li>
        <li class="breadcrumb-item"><a asp-controller="Orders" asp-action="Index">Заказы</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Order.Number</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Заказ @Model.Order.Number</h1>
    @if (Model.Edit)
    {
        <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Order.Id">Готово</a>
    }
    else
    {
        <a class="btn btn-primary" asp-action="Details" asp-route-id="@Model.Order.Id" asp-route-edit="true">Изменить</a>
    }
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<h5 class="mb-3">Трудозатраты</h5>

@if (Model.Edit)
{
    <form asp-controller="Orders" asp-action="AddLaborCost" asp-route-id="@Model.Order.Id" method="post"
          class="row g-2 mb-4 align-items-end">
        <div class="col-md-4">
            <label class="form-label mb-0">Работник</label>
            <select name="employeeId" class="form-select" required>
                <option value="" disabled selected>Работник…</option>
                @foreach (var e in Model.Employees)
                {
                    <option value="@e.Id">@e.LastName @e.FirstName</option>
                }
            </select>
        </div>
        <div class="col-md-4">
            <label class="form-label mb-0">Расценка (операция · ставка)</label>
            <select name="productionRateId" class="form-select" required>
                <option value="" disabled selected>Расценка…</option>
                @foreach (var r in Model.Rates)
                {
                    <option value="@r.Id">@r.OperationName · @r.Rate</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label mb-0">Кол-во</label>
            <input name="quantity" type="number" min="1" step="1" class="form-control" required />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Добавить</button>
        </div>
    </form>
}

@if (Model.Costs.Count == 0)
{
    <p class="text-muted">Трудозатрат пока нет.</p>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Работник</th>
                <th>Операция</th>
                <th style="width:120px">Ставка</th>
                <th style="width:160px">Кол-во</th>
                <th style="width:120px">Сумма</th>
                @if (Model.Edit)
                {
                    <th style="width:120px"></th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model.Costs)
            {
                <tr>
                    <td>@c.EmployeeName</td>
                    <td>@c.OperationName</td>
                    <td>@c.Rate</td>
                    <td>
                        @if (Model.Edit)
                        {
                            <form asp-controller="Orders" asp-action="EditLaborCost" asp-route-id="@Model.Order.Id"
                                  asp-route-costId="@c.Id" method="post" class="d-flex gap-2">
                                <input name="quantity" value="@c.Quantity" type="number" min="1" step="1"
                                       class="form-control form-control-sm" required />
                                <button type="submit" class="btn btn-sm btn-outline-primary">OK</button>
                            </form>
                        }
                        else
                        {
                            @c.Quantity
                        }
                    </td>
                    <td>@c.Sum</td>
                    @if (Model.Edit)
                    {
                        <td>
                            <form asp-controller="Orders" asp-action="DeleteLaborCost" asp-route-id="@Model.Order.Id"
                                  asp-route-costId="@c.Id" method="post"
                                  onsubmit="return confirm('Удалить трудозатрату?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Удалить</button>
                            </form>
                        </td>
                    }
                </tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <th colspan="4" class="text-end">Итого:</th>
                <th>@Model.Total</th>
                @if (Model.Edit)
                {
                    <th></th>
                }
            </tr>
        </tfoot>
    </table>
}
